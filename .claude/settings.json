{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:cdn.jsdelivr.net)",
      "WebFetch(domain:cdnjs.cloudflare.com)",
      "WebFetch(domain:unpkg.com)",
      "WebFetch(domain:fontawesome.com)",
      "WebFetch(domain:primer.style)",
      "WebFetch(domain:sdpf.ntt.com)",
      "WebFetch(domain:docs.sdk.qmonus.net)",
      "WebFetch(domain:docs.valuestream.qmonus.net)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "allowRead": [".", "~/.npm/", "~/.npmrc"],
      "allowWrite": ["~/.npm/"]
    },
    "network": {
      "allowedDomains": [
        "www.npmjs.com",
        "registry.npmjs.org",
        "cdn.jsdelivr.net",
        "cdnjs.cloudflare.com",
        "unpkg.com",
        "fontawesome.com",
        "primer.style",
        "sdpf.ntt.com",
        "docs.sdk.qmonus.net",
        "docs.valuestream.qmonus.net"
      ]
    }
  }
}
